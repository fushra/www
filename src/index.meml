(head
    (title "Fushra | Home")
    (link rel="preconnect" href="https://cdn.fushra.com")
    "<script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{\"token\":\"2e43d9440690412393887a2b38c21057\"}'></script>"
    "
      <meta charset='UTF-8'>
      <meta http-equiv='X-UA-Compatible' content='IE=edge'>
      <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    "

    (import "./index.css")
    (import "https://cdn.fushra.com/plusjakartasans.css")
)
(body
    (header
        (div
            (h1 "Fushra")
            (p "Creating a simpler web for everyone")
            (p
                (a href="https://github.com/fushra/meml" "MEML prototype") " • "
                (a href="https://github.com/fivnex/meml/blob/master/docs/syntaxStandard.md" "MEML standard") " • "
                (a href="https://discord.gg/xNkretH7sD" "Fushra Discord") " • "
                (a href="https://link.fivnex.co/join" "Fivnex discord")
            )
        )
    )

    (footer
        (p "&#169; Fivnex 2021. This was the first website made using meml")
    )
)
